import java.util.Scanner;

class SumUntilZeroUsingWhile {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int sum = 0;
        int num;
        System.out.println("Enter numbers (enter 0 to stop):");
        num = sc.nextInt();

        while (num != 0) {
            sum = sum + num;
            num = sc.nextInt();
        }

        System.out.println("Sum = " + sum);
    }
}
